// BLOG MODELS
// Article management with multi-author support and category taxonomy

model BlogArticle {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  titleNormalized String? // Normalized for accent-insensitive search (Greek)
  excerpt         String?  @db.Text
  content         String   @db.Text // Rich HTML from TipTap editor
  coverImage      String? // Cloudinary URL (featured image)

  // Taxonomy
  categoryId String
  tags       String[] // Future use

  // Publishing
  status      Status   @default(draft) // Reuses enum from service.prisma
  featured    Boolean  @default(false)
  publishedAt DateTime?

  // Metrics
  viewCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category BlogCategory       @relation(fields: [categoryId], references: [id])
  authors  BlogArticleAuthor[]
  savedBy  SavedArticle[]

  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([status, featured, publishedAt])
  @@index([titleNormalized])
  @@map("blog_articles")
}

// Many-to-many: an article can have multiple author profiles
model BlogArticleAuthor {
  id        String @id @default(cuid())
  articleId String
  profileId String
  order     Int    @default(0) // Display order of authors

  article BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([articleId, profileId])
  @@index([articleId])
  @@index([profileId])
  @@map("blog_article_authors")
}

model BlogCategory {
  id          String  @id @default(cuid())
  slug        String  @unique
  label       String // Display name
  description String?
  order       Int     @default(0) // Sort order in tabs

  articles BlogArticle[]

  @@map("blog_categories")
}

model SavedArticle {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  article BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
  @@map("saved_articles")
}
