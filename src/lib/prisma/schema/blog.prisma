// BLOG MODELS
// Article management with multi-author support

model BlogArticle {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  titleNormalized String? // Normalized for accent-insensitive search (Greek)
  excerpt         String?  @db.Text
  content         String   @db.Text // Rich HTML from TipTap editor
  /// [CloudinaryResource]
  coverImage      Json? // Cloudinary resource object (featured image)

  // Taxonomy
  categorySlug String? // Matches slug from static blog-categories constants

  // Publishing
  status      Status   @default(draft) // Reuses enum from service.prisma
  featured    Boolean  @default(false)
  publishedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  authors BlogArticleAuthor[]

  @@index([categorySlug])
  @@index([status, publishedAt])
  @@index([status, featured, publishedAt])
  @@index([titleNormalized])
  @@map("blog_articles")
}

// Many-to-many: an article can have multiple author profiles
model BlogArticleAuthor {
  id        String @id @default(cuid())
  articleId String
  profileId String
  order     Int    @default(0) // Display order of authors

  article BlogArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([articleId, profileId])
  @@index([articleId])
  @@index([profileId])
  @@map("blog_article_authors")
}
